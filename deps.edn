{:paths ["src"]
 ;; kotoba-code — a model-neutral, test-gated, kotoba-Datom-backed agentic coding
 ;; agent. Built on the kotoba-clj stack:
 ;;   langchain-clj — ChatModel (openai-model → OpenRouter/Murakumo) + tools + kotoba-db
 ;;   langgraph-clj — create-react-agent loop + datomic-checkpointer (kotoba persistence)
 ;; Sibling local roots under orgs/com-junkawasaki/. The top-level langchain-clj
 ;; :local/root overrides langgraph-clj's transitive git dep so the stack resolves
 ;; offline against the local checkouts.
 :deps {io.github.com-junkawasaki/langchain-clj {:local/root "../langchain-clj"}
        io.github.com-junkawasaki/langgraph-clj {:local/root "../langgraph-clj"}
        org.clojure/data.json {:mvn/version "2.5.0"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; drive a coding task:  clojure -M:run "<task>" <project-root> [model-id]
  :run {:main-opts ["-m" "kotoba-code.main"]}}}
